# ---- LiveKit Server ----
LK_LIVEKIT_URL=ws://localhost:7880
LK_LIVEKIT_API_KEY=devkey
LK_LIVEKIT_API_SECRET=secret

# ---- LiveKit SIP ----
LK_SIP_TRUNK_ID=
LK_SIP_OUTBOUND_NUMBER=
LK_SIP_DOMAIN=

# ---- Aliyun ASR (Paraformer via DashScope) ----
LK_ALIYUN_ASR_API_KEY=
LK_ALIYUN_ASR_MODEL=paraformer-realtime-v2

# ---- Aliyun TTS (CosyVoice via DashScope) ----
LK_ALIYUN_TTS_API_KEY=
LK_ALIYUN_TTS_MODEL=cosyvoice-v1
LK_ALIYUN_TTS_VOICE=longxiaochun

# ---- Aliyun LLM (Qwen via DashScope OpenAI compat) ----
LK_ALIYUN_LLM_API_KEY=
LK_ALIYUN_LLM_MODEL=qwen-plus

# ---- PostgreSQL ----
LK_PG_HOST=localhost
LK_PG_PORT=5432
LK_PG_USER=postgres
LK_PG_PASSWORD=postgres
LK_PG_DATABASE=ai_outbound_livekit

# ---- Redis ----
LK_REDIS_URL=redis://localhost:6379/0

# ---- Server ----
LK_API_HOST=0.0.0.0
LK_API_PORT=8000
LK_DEBUG=false
LK_LOG_LEVEL=INFO

# ---- Kamailio (Softphone SIP Registrar) ----
# Kamailio SIP 域名
LK_KAMAILIO_SIP_DOMAIN=localhost
# Kamailio 对外 SIP 端口（容器内 5060 映射到宿主机 5080）
LK_KAMAILIO_SIP_PORT=5080

# ---- SIP Provider (PSTN 网关) ----
# SIP 供应商对接 IP
LK_SIP_PROVIDER_HOST=59.110.91.40
# SIP 供应商端口
LK_SIP_PROVIDER_PORT=6922
# 主叫号码（设置在 SIP From 头中）
LK_SIP_PROVIDER_CALLER_ID=202603311547
# 拨号前缀（拨打手机号时在号码前添加此前缀）
LK_SIP_PROVIDER_PREFIX=97776

# ---- Kamailio Database (独立数据库，不与业务库混用) ----
LK_KAMAILIO_DB_HOST=postgres
LK_KAMAILIO_DB_PORT=5432
LK_KAMAILIO_DB_NAME=kamailio
LK_KAMAILIO_DB_USER=postgres
LK_KAMAILIO_DB_PASSWORD=postgres
