FROM python:3.12-slim

WORKDIR /app

# 安装 Python 依赖（使用预编译 wheel，无需 build-essential）
COPY livekit_backend/pyproject.toml /app/livekit_backend/
RUN pip install --no-cache-dir --prefer-binary /app/livekit_backend/ && \
    pip install --no-cache-dir minio>=7.2.0

# 复制代码
COPY . /app/

# 设置 Python 路径
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 8000
