# ============================================================
# 智能外呼系统环境变量配置
# 复制为 .env 并填写实际值
# cp .env.example .env
# ============================================================


# ── LLM ──────────────────────────────────────────────────────
# Anthropic Claude API Key（必填）
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# 使用的模型（推荐 claude-sonnet-4-20250514）
LLM_MODEL=claude-sonnet-4-20250514

# 最大输出 Token 数（外呼场景 300-500 即可）
LLM_MAX_TOKENS=500

# 温度（0.3~0.5 保证话术稳定性）
LLM_TEMPERATURE=0.4

# 对话历史保留轮数
LLM_MAX_HISTORY=20

# 是否启用流式输出
LLM_STREAM=true


# ── FreeSWITCH ESL ────────────────────────────────────────────
# FreeSWITCH 所在服务器 IP
FS_HOST=127.0.0.1

# ESL Inbound 端口（与 event_socket.conf.xml 一致）
FS_ESL_PORT=8021

# ESL 认证密码（与 event_socket.conf.xml 一致）
FS_ESL_PASSWORD=ClueCon

# ESL Socket Server 端口（后端监听，FreeSWITCH 主动连接）
FS_SOCKET_PORT=9999

# 运营商 SIP 网关名称（与 sofia.conf.xml 中 gateway name 一致）
FS_GATEWAY=carrier_trunk

# 外呼超时（秒）
FS_ORIGINATE_TIMEOUT=30

# 录音文件存储路径
FS_RECORDING_PATH=/recordings


# ── ASR 语音识别 ───────────────────────────────────────────────
# 提供商：funasr_local | xunfei | ali | mock（开发测试用）
ASR_PROVIDER=mock

# FunASR 本地服务（当 ASR_PROVIDER=funasr_local 时）
FUNASR_HOST=127.0.0.1
FUNASR_PORT=10095

# 讯飞 ASR（当 ASR_PROVIDER=xunfei 时）
XUNFEI_APPID=
XUNFEI_APIKEY=
XUNFEI_APISECRET=

# ── 阿里云智能语音交互 NLS（当 ASR_PROVIDER=ali 时）──────────
#
# 开通步骤：
#   1. 阿里云控制台 → 搜索「智能语音交互」→ 立即开通
#   2. 进入控制台 → 项目管理 → 创建项目 → 复制 AppKey
#   3. RAM 控制台 → 创建用户 → 授权 AliyunNLSFullAccess → 创建 AccessKey
#
# 文档：https://help.aliyun.com/document_detail/84428.html
#
# AppKey（每个 NLS 项目唯一，控制台「项目管理」页面可见）
ALI_ASR_APPKEY=

# RAM 子账号 AccessKey（推荐方式，权限最小化）
ALI_ACCESS_KEY_ID=
ALI_ACCESS_KEY_SECRET=

# NLS Token（可选，直接填写跳过 AK/SK 换取流程，有效期 24h）
# 适合快速测试，生产环境用 AK/SK 自动刷新
ALI_NLS_TOKEN=

# NLS 服务地址（选择离业务最近的区域）
# 上海（默认）: wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1
# 北京:        wss://nls-gateway-cn-beijing.aliyuncs.com/ws/v1
ALI_NLS_URL=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1

# 是否返回中间识别结果（true=边说边显示, false=只返回整句）
# 外呼场景建议 true，可更快检测到用户意图
ALI_ASR_INTERMEDIATE=true

# 是否开启标点预测（对 LLM 理解句意有帮助）
ALI_ASR_PUNCTUATION=true

# 是否开启数字转写（"一百二十三" → "123"）
ALI_ASR_ITN=true

# 热词 ID（在阿里云控制台配置，提升产品名/品牌词识别率，可留空）
ALI_ASR_VOCABULARY_ID=

# 通用参数
# 采样率（Hz），与 FreeSWITCH 编解码器匹配：PCMU/PCMA=8000
ASR_SAMPLE_RATE=8000

# VAD 静音检测阈值（ms），超过此时长静音则认为用户说完话
VAD_SILENCE_MS=500


# ── TTS 语音合成 ───────────────────────────────────────────────
# 提供商：ali | edge（免费）| cosyvoice_local | mock（开发测试用）
TTS_PROVIDER=mock

# 阿里云 TTS（当 TTS_PROVIDER=ali 时）
ALI_TTS_APPKEY=
ALI_TTS_TOKEN=

# CosyVoice 本地服务地址（当 TTS_PROVIDER=cosyvoice_local 时）
COSYVOICE_URL=http://127.0.0.1:50000

# 发音人（因 TTS 提供商而异，参考各自文档）
TTS_VOICE=zhilingxi

# 语速（0.5=慢, 1.0=正常, 1.2=稍快）
TTS_SPEECH_RATE=1.0

# 合成音频临时存放目录
TTS_OUTPUT_DIR=/tmp/tts_cache


# ── 数据库 ────────────────────────────────────────────────────
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://postgres:password@localhost:5432/outbound_call

# 开发模式可用 SQLite
# DATABASE_URL=sqlite+aiosqlite:///./outbound_call.db


# ── Redis（任务队列）─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0


# ── 应用配置 ──────────────────────────────────────────────────
# 最大并发外呼路数
MAX_CONCURRENT_CALLS=50

# 单路通话最长时长（秒），超时强制挂断防止僵尸通话
MAX_CALL_DURATION=300

# API 访问令牌（Bearer Token 鉴权）
# 留空 = 不鉴权（仅供本地开发，生产必须设置）
API_TOKEN=your_secret_token_here

# 话术脚本 JSON 文件路径（不设置则使用内置话术）
# 文件格式参考 README.md 中的话术脚本热加载章节
# 重启服务后生效
SCRIPTS_PATH=

# API 服务端口
API_PORT=8000

# 调试模式（开发时 true，生产时 false）
DEBUG=false
