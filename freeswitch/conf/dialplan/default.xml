<?xml version="1.0" encoding="utf-8"?>
<include>
  <context name="default">

    <!-- 通用 park 扩展，用于 originate 后保持 A-leg -->
    <extension name="park">
      <condition field="destination_number" expression="^park$">
        <action application="park"/>
      </condition>
    </extension>

    <!-- AI 外呼 B-leg 处理（ originate 创建的 B-leg 在 default context 中） -->
    <!-- 只匹配 PSTN 外呼：destination_number 是 97776+手机号（16位） -->
    <extension name="ai_outbound_bleg">
      <condition field="${ai_agent}" expression="^true$" break="never"/>
      <condition field="destination_number" expression="^97776\d{11}$">
        <action application="set" data="origination_uuid=${export_origination_uuid}"/>
        <action application="answer"/>
        <action application="sleep" data="500"/>
        <action application="set" data="RECORD_STEREO=false"/>
        <action application="set" data="media_bug_answer_req=true"/>
        <action application="set" data="record_file=/recordings/${uuid}.wav"/>
        <action application="record_session" data="/recordings/${uuid}.wav"/>
        <action application="socket" data="backend:9999 async full"/>
      </condition>
    </extension>

    <!-- AI Agent Test Extensions -->
    <extension name="AI_Agent_Test">
      <condition field="destination_number" expression="^2000$">
        <action application="answer"/>
        <action application="sleep" data="1000"/>
        <action application="set" data="effective_caller_id_name=AI_Test_Caller"/>
        <action application="set" data="effective_caller_id_number=2001"/>
        <!-- 将通话连接到后端 AI 代理 -->
        <action application="set" data="ai_agent=true"/>
        <action application="set" data="task_id=test_ai_call"/>
        <action application="set" data="script_id=default"/>
        <action application="socket" data="$${backend_socket_host}:$${backend_socket_port} async full"/>
      </condition>
    </extension>

    <extension name="AI_Agent_Inbound_Test">
      <condition field="destination_number" expression="^3000$">
        <action application="answer"/>
        <action application="sleep" data="200"/>
        <action application="set" data="media_bug_answer_req=true"/>
        <action application="set" data="RECORD_STEREO=false"/>
        <action application="set" data="record_file=/recordings/${uuid}.wav"/>
        <action application="record_session" data="/recordings/${uuid}.wav"/>
        <!-- 将通话连接到后端 AI 代理 -->
        <action application="set" data="ai_agent=true"/>
        <action application="set" data="task_id=inbound_ai_test"/>
        <action application="set" data="script_id=default"/>
        <action application="socket" data="backend:9999 async full"/>
      </condition>
    </extension>

    <extension name="outbound_to_provider">
      <condition field="destination_number" expression="^(1[3-9]\d{9})$">

        <!-- <action application="set" data="effective_caller_id_number=202603311547"/> -->

        <!-- Route through carrier trunk with provider-required prefix 97776 -->
        <action application="bridge" data="sofia/gateway/carrier_trunk/$${provider_prefix}$1"/>

      </condition>
    </extension>

    <!-- AI 外呼 A-leg 处理（loopback/AI_CALL 匹配此扩展） -->
    <extension name="ai_call_handler">
      <condition field="destination_number" expression="^AI_CALL$">
        <action application="answer"/>
        <action application="sleep" data="500"/>
        <!-- 从 originate export 变量中读取被叫号码（PSTN 场景下传递） -->
        <action application="set" data="callee_number=${export_callee_number}"/>
        <!-- 确保 RTP 经过 FreeSWITCH 软件层，防止 P2P 旁路导致音频捕获失败 -->
        <action application="set" data="proxy_media=true"/>
        <action application="set" data="bypass_media=false"/>
        <action application="set" data="RECORD_STEREO=false"/>
        <action application="set" data="media_bug_answer_req=true"/>
        <action application="set" data="record_file=/recordings/${uuid}.wav"/>
        <action application="record_session" data="/recordings/${uuid}.wav"/>
        <!-- 注意：不在这里播放 opening_greeting，因为 &bridge() 是异步的，
              playback 可能在 sofia 侧用户应答前就执行了。
             开场白由 CallAgent 在 socket 连接后通过 uuid_displace 播放。 -->
        <action application="socket" data="backend:9999 async full"/>
      </condition>
    </extension>

    <!-- 内部 AI 呼叫处理：当 ai_agent=true 且拨打内部号码时 -->
    <extension name="internal_ai_call_handler">
      <condition field="${ai_agent}" expression="^true$"/>
      <condition field="${destination_number}" expression="^(1001|1002|10[01][0-9])$"/>
      <action application="set" data="dialed_extension=${destination_number}"/>
      <action application="answer"/>
      <action application="sleep" data="500"/>
      <!-- 确保 RTP 经过 FreeSWITCH 软件层 -->
      <action application="set" data="proxy_media=true"/>
      <action application="set" data="bypass_media=false"/>
      <action application="set" data="RECORD_STEREO=false"/>
      <action application="set" data="media_bug_answer_req=true"/>
      <action application="set" data="record_file=/recordings/${uuid}.wav"/>
      <action application="record_session" data="/recordings/${uuid}.wav"/>
      <action application="socket" data="backend:9999 async full"/>
      <action application="bridge" data="user/${dialed_extension}@${domain}"/>
    </extension>

    <!-- 外呼通话处理 - 被叫接通后交给 ESL socket 应用 -->
    <extension name="ai_outbound_answered">
      <condition field="${direction}" expression="^outbound$"/>
      <condition field="${ai_agent}" expression="^true$"/>
      <action application="answer"/>
      <action application="sleep" data="500"/>
      <action application="set" data="RECORD_STEREO=false"/>
      <action application="set" data="media_bug_answer_req=true"/>
      <action application="set" data="record_file=/recordings/${uuid}.wav"/>
      <action application="record_session" data="/recordings/${uuid}.wav"/>
      <action application="socket" data="backend:9999 async full"/>
    </extension>

    <!-- 转接人工坐席 -->
    <extension name="transfer_to_human">
      <condition field="destination_number" expression="^human_agent_(\d+)$">
        <action application="playback" data="tone_stream://%(400,200,440);loops=3"/>
        <action application="set" data="transfer_source=ai_agent"/>
        <action application="transfer" data="$1 XML agents"/>
      </condition>
    </extension>

  </context>

</include>
