<?xml version="1.0" encoding="utf-8"?>
<include>
  <context name="default">

  <extension name="auto_prefix_outbound">
    <condition field="destination_number" expression="^(\d{11})$">

      <action application="set" data="effective_caller_id_number=202603311547"/>

      <!-- Route through carrier trunk with provider-required prefix 97776 -->
      <action application="bridge" data="sofia/gateway/carrier_trunk/97776$1"/>

    </condition>
  </extension>

    <!-- 外呼通话处理 - 被叫接通后交给 ESL socket 应用 -->
    <extension name="ai_outbound_answered">
      <condition field="${direction}" expression="^outbound$">
      <condition field="${ai_agent}" expression="^true$">
        <action application="answer"/>
        <action application="set" data="RECORD_STEREO=false"/>
        <action application="set" data="media_bug_answer_req=true"/>
        <!-- 开始录音（合规要求） -->
        <action application="set" data="record_file=/recordings/${uuid}.wav"/>
        <action application="record_session" data="/recordings/${uuid}.wav"/>
        <!-- 将通话控制权交给后端 call_agent.py -->
        <action application="socket" data="backend:9999 async full"/>
      </condition>
      </condition>
    </extension>

    <!-- 转接人工坐席 -->
    <extension name="transfer_to_human">
      <condition field="destination_number" expression="^human_agent_(\d+)$">
        <action application="playback" data="tone_stream://%(400,200,440);loops=3"/>
        <action application="set" data="transfer_source=ai_agent"/>
        <action application="transfer" data="$1 XML agents"/>
      </condition>
    </extension>

  </context>

  <context name="agents">
    <extension name="agent_queue">
      <condition field="destination_number" expression="^\d+$">
        <action application="answer"/>
        <action application="fifo" data="agent_queue@default in /recordings/wait_music.wav"/>
      </condition>
    </extension>
  </context>

</include>
