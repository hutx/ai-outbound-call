<?xml version="1.0" encoding="utf-8"?>
<!--
  内部分机拨号计划
  用于测试 AI 通话等功能
-->
<include>

  <!-- ============================================================
       内部通话上下文
       ============================================================ -->
  <context name="internal">

    <!-- ============================================================ -->
    <!-- 通用 AI 扩展已移至 ai_call_handler (default.xml loopback) -->

    <!-- AI_Handler：&park() + uuid_transfer 入口
         无 bridge → 无 RTP 旁路 → TTS 能正确播放
         socket(async full) 建立 ESL Outbound 连接，捕获音频 + 播放 TTS -->
    <extension name="AI_Handler">
      <condition field="destination_number" expression="^9998$">
        <action application="answer" />
        <action application="sleep" data="200" />
        <action application="set" data="RECORD_STEREO=false" />
        <action application="set" data="media_bug_answer_req=true" />
        <action application="set" data="record_file=/recordings/${uuid}.wav" />
        <action application="record_session" data="/recordings/${uuid}.wav" />
        <action application="socket"
          data="backend:9999 async full" />
      </condition>
    </extension>

    <!-- AI 外呼 A-leg：录制用户语音 → 桥接到 AI_Handler (loopback)
         record_session 在 bridge 之前执行，确保捕获用户 RTP 音频
         录制到 /recordings/{sofia_a_leg_uuid}.wav -->
    <extension name="AI_Caller">
      <condition field="destination_number" expression="^9997$">
        <action application="answer" />
        <action application="sleep" data="200" />
        <action application="set" data="RECORD_STEREO=false" />
        <action application="set" data="media_bug_answer_req=true" />
        <action application="set" data="record_file=/recordings/${uuid}.wav" />
        <action application="record_session" data="/recordings/${uuid}.wav" />
        <action application="sleep" data="300" />
        <action application="set" data="ai_caller=true" />
        <action application="bridge" data="loopback/AI_CALL:default" />
      </condition>
    </extension>

    <!-- 内部直拨：分机 1000-1099 -->
    <!-- ★ 使用 loopback B-leg 承载 forkzstream + AI 对话，sofia A-leg 桥接到 loopback。
         这样确保 sofia 侧 RTP 一定经过 FreeSWITCH 软件层，forkzstream 能正确捕获用户语音。
         架构：sofia A-leg → bridge(loopback/AI_CALL) → AI handler → bridge(user/分机) -->
    <extension name="Local_Extension">
      <condition field="destination_number" expression="^(10\d{2})$">
        <action application="export" data="callee_number=$1" />
        <action application="set" data="continue_on_fail=NORMAL_TEMPORARY_FAILURE,USER_BUSY,NO_ANSWER,TIMEOUT,EXTENSION_NOT_FOUND,INVALID_NUMBER_FORMAT,DOMAIN_NOT_FOUND" />
        <action application="set" data="ringback=${us-ring}" />
        <action application="set" data="transfer_ringback=${us-ring}" />
        <action application="set" data="call_timeout=30" />
        <action application="set" data="hangup_after_bridge=true" />
        <!-- ★ 确保 RTP 经过 FreeSWITCH 软件层，使 forkzstream 能捕获用户语音 -->
        <action application="set" data="proxy_media=true" />
        <action application="set" data="bypass_media=false" />
        <!-- ★ sofia A-leg 录制用户语音 -->
        <action application="set" data="RECORD_STEREO=false" />
        <action application="set" data="media_bug_answer_req=true" />
        <action application="set" data="record_file=/recordings/${uuid}.wav" />
        <action application="record_session" data="/recordings/${uuid}.wav" />
        <!-- ★ 桥接到 loopback B-leg，forkzstream + AI 在 loopback 上执行 -->
        <action application="bridge" data="loopback/AI_CALL:default" />
      </condition>
    </extension>

    <!-- 测试 AI 代理 - 拨打 2000 转接到 AI 代理 -->
    <extension name="AI_Agent_Test">
      <condition field="destination_number" expression="^2000$">
        <action application="answer" />
        <action application="sleep" data="1000" />
        <action application="set" data="effective_caller_id_name=AI_Test_Caller" />
        <action application="set" data="effective_caller_id_number=2001" />
        <!-- 将通话连接到后端 AI 代理 -->
        <action application="set" data="ai_agent=true" />
        <action application="set" data="task_id=test_ai_call" />
        <action application="set" data="script_id=default" />
        <action application="socket"
          data="$${backend_socket_host}:$${backend_socket_port} async full" />
      </condition>
    </extension>

    <!-- 测试 AI 代理 - 拨打 3000 转接到 AI 代理（作为被叫）-->
    <extension name="AI_Agent_Inbound_Test">
      <condition field="destination_number" expression="^3000$">
        <condition field="${context}" expression="internal" />
        <action application="answer" />
        <action application="sleep" data="200" />
        <action application="set" data="media_bug_answer_req=true" />
        <action application="set" data="RECORD_STEREO=false" />
        <action application="set" data="record_file=/recordings/${uuid}.wav" />
        <action application="record_session" data="/recordings/${uuid}.wav" />
        <!-- 将通话连接到后端 AI 代理 -->
        <action application="set" data="ai_agent=true" />
        <action application="set" data="task_id=inbound_ai_test" />
        <action application="set" data="script_id=default" />
        <action application="socket"
          data="$${backend_socket_host}:$${backend_socket_port} async full" />
      </condition>
    </extension>

    <!-- 会议桥接测试 -->
    <extension name="EasyConference">
      <condition field="destination_number"
        expression="^confctl(\d+)@(.*)$|^(.*)@confctl(\d+)$|^conf(\d+)$">
        <action application="answer" />
        <action application="conference" data="$1$2$3$4@$${domain}" />
      </condition>
    </extension>

    <!-- 语音邮箱 -->
    <extension name="voicemail_main">
      <condition field="destination_number" expression="^voicemail$|^8501$|^pickup$" />
      <condition field="authorize" expression="all" />
      <action application="answer" />
      <action application="sleep" data="1000" />
      <action application="voicemail" data="check default ${domain}" />
    </extension>

    <!-- 语音邮箱用户 -->
    <extension name="voicemail_single">
      <condition field="destination_number" expression="^8(1[0-9][0-9])$">
        <condition field="network_addr" expression="^$${local_network_acl}$" />
        <action application="answer" />
        <action application="sleep" data="1000" />
        <action application="voicemail" data="check $1 default ${domain}" />
      </condition>
    </extension>

    <!-- 通话记录 -->
    <extension name="call_return">
      <condition field="destination_number" expression="^(\*66)$">
        <action application="set" data="called_party_call_return=${call_return_${caller_id_number}}" />
        <action application="unset" data="continue_on_fail" />
        <action application="transfer" data="${called_party_call_return}" />
      </condition>
    </extension>

    <!-- 盲转 -->
    <extension name="transfer_blind">
      <condition field="destination_number" expression="^(70[01][0-9])$">
        <action application="transfer" data="$1 XML internal" />
      </condition>
    </extension>

    <!-- 闹钟服务 -->
    <extension name="alarm">
      <condition field="destination_number" expression="^alarm$|^3322$" />
      <action application="answer" />
      <action application="sleep" data="1000" />
        <action application="playback" data="alarm-message.wav" />
        <action application="log" data="ALARM MESSAGE PLAYED FOR ${caller_id_number}" />
    </extension>

    <!-- 电话簿 -->
    <extension name="directory">
      <condition field="destination_number" expression="^(5000)$" />
      <action application="answer" />
      <action application="sleep" data="1000" />
      <action application="directory" data="default XML" />
    </extension>

  </context>

</include>
