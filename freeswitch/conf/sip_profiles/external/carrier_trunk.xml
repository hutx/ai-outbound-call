<include>
  <!-- Carrier trunk configuration for outbound calling -->
  <!-- This configuration must match the gateway referenced in sofia.conf.xml -->
  <gateway name="carrier_trunk">
    <!-- SIP Provider Information -->
    <!-- IP: 59.110.91.40, Port: 6922, Caller ID: 202603311547, Prefix: 97776 -->
    <!-- Provider uses IP whitelist/direct line对接 -->
    <param name="realm" value="59.110.91.40:6922"/>
    <param name="username" value="202603311547"/>
    <param name="password" value="your_password_here"/>  <!-- Will need to be provided separately -->

    <!-- Provider specific settings -->
    <param name="from-user" value="202603311547"/>
    <param name="from-domain" value="59.110.91.40"/>
    <param name="proxy" value="59.110.91.40:6922"/>
    <param name="register-proxy" value="59.110.91.40:6922"/>
    <param name="outbound-proxy" value="59.110.91.40:6922"/>

    <!-- Registration settings -->
    <param name="expire-seconds" value="600"/>
    <param name="register" value="true"/> <!-- Changed to true since provider uses IP whitelist -->

    <!-- Codec settings -->
    <param name="extension-in-contact" value="true"/>
    <param name="retry-seconds" value="30"/>
    <param name="contact-params" value="tport=udp"/>

    <!-- Additional parameters for IP whitelist provider -->
    <param name="caller-id-in-from" value="true"/>
    <param name="ping" value="25"/>
    <param name="ping-max" value="3"/>
    <param name="ping-min" value="1"/>
    <param name="register-transport" value="udp"/>
  </gateway>
</include>