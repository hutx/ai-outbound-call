<!-- 内部用户配置，用于测试 AI 通话 -->
<include>
  <!-- 1000 分机 - AI 机器人 -->
  <user id="1000">
    <params>
      <param name="password" value="1234"/>
      <param name="vm-password" value="1234"/>
    </params>
    <variables>
      <variable name="toll_allow" value="domestic,international,local"/>
      <variable name="accountcode" value="1000"/>
      <variable name="user_context" value="internal"/>
      <variable name="effective_caller_id_name" value="AI Agent"/>
      <variable name="effective_caller_id_number" value="1000"/>
      <variable name="outbound_caller_id_name" value="AI Agent"/>
      <variable name="outbound_caller_id_number" value="1000"/>
      <variable name="callgroup" value="techsupport"/>
    </variables>
  </user>

  <!-- 1001 分机 - 测试用户 -->
  <user id="1001">
    <params>
      <param name="password" value="1234"/>
      <param name="vm-password" value="1234"/>
    </params>
    <variables>
      <variable name="toll_allow" value="domestic,international,local"/>
      <variable name="accountcode" value="1001"/>
      <variable name="user_context" value="internal"/>
      <variable name="effective_caller_id_name" value="Test User"/>
      <variable name="effective_caller_id_number" value="1001"/>
      <variable name="outbound_caller_id_name" value="Test User"/>
      <variable name="outbound_caller_id_number" value="1001"/>
      <variable name="callgroup" value="techsupport"/>
    </variables>
  </user>
</include>