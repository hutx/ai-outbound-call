<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║  mod_audio_stream 配置                                       ║
  ║                                                              ║
  ║  这是将 FreeSWITCH 实时音频推送到 WebSocket 的核心模块       ║
  ║  ASR 通过 WebSocket 接收 PCM 音频流，无需轮询，延迟最低      ║
  ║                                                              ║
  ║  安装步骤：                                                   ║
  ║  1. git clone https://github.com/nicholasinatel/mod_audio_stream ║
  ║  2. cp -r mod_audio_stream /usr/src/freeswitch/src/mod/applications/ ║
  ║  3. cd /usr/src/freeswitch                                   ║
  ║  4. ./bootstrap.sh                                           ║
  ║  5. ./configure                                              ║
  ║  6. make mod_audio_stream-install                            ║
  ║                                                              ║
  ║  使用方法（在拨号计划或 ESL 中）：                            ║
  ║  <action application="audio_stream"                          ║
  ║    data="ws://127.0.0.1:8765 16000 mixed 20"/>               ║
  ║  参数：WebSocket地址 采样率 通道(mixed/read/write) 包大小ms   ║
  ╚══════════════════════════════════════════════════════════════╝
-->
<configuration name="audio_stream.conf" description="实时音频流推送">
  <settings>
    <!-- 默认 WebSocket 目标（后端 ASR 接收服务地址） -->
    <param name="default-url"     value="ws://127.0.0.1:8765"/>
    <!-- 默认采样率（Hz）：8000 标准电话，16000 更高 ASR 精度 -->
    <param name="default-rate"    value="8000"/>
    <!-- 默认音频包大小（毫秒）：20ms 为实时语音标准 -->
    <param name="default-ms"      value="20"/>
    <!-- 默认通道：mixed=双向混音, read=被叫声音, write=主叫声音 -->
    <param name="default-channel" value="read"/>
    <!-- 连接超时（毫秒） -->
    <param name="connect-timeout" value="3000"/>
    <!-- 重连间隔（毫秒） -->
    <param name="reconnect-interval-ms" value="1000"/>
  </settings>
</configuration>
