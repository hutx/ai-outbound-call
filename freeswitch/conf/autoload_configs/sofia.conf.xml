<configuration name="sofia.conf" description="sofia Endpoint">

  <global_settings>
    <param name="log-level" value="0"/>
    <!-- <param name="abort-on-empty-external-ip" value="true"/> -->
    <!-- <param name="auto-restart" value="false"/> -->
    <param name="debug-presence" value="0"/>
    <!-- <param name="capture-server" value="udp:homer.domain.com:5060"/> -->
    
    <!-- 
    	the new format for HEPv2/v3 and capture ID    
	
	protocol:host:port;hep=2;capture_id=200;

    -->
    
    <!-- <param name="capture-server" value="udp:homer.domain.com:5060;hep=3;capture_id=100"/> -->
  </global_settings>

  <!--
      The rabbit hole goes deep.  This includes all the
      profiles in the sip_profiles directory that is up
      one level from this directory.
  -->
  <profiles>
    <!-- ============================================================
         外呼专用 Profile
         端口 5080，专门处理运营商中继外呼
         ============================================================ -->
    <profile name="outbound">

      <gateways>
        <!--
          ★ 主运营商 SIP 网关
          替换为实际运营商信息后生效
          国内常用：阿里云通信 / 华为云 / 天翼云 / 云讯
        -->
        <gateway name="carrier_trunk">
          <param name="username"         value="$${carrier_username}"/>
          <param name="password"         value="$${carrier_password}"/>
          <param name="realm"            value="$${carrier_sip_server}:6922"/>
          <param name="proxy"            value="$${carrier_sip_server}:6922"/>
          <param name="register"         value="false"/>
          <param name="expire-seconds"   value="1800"/>
          <param name="retry-seconds"    value="30"/>
          <param name="register-transport" value="udp"/>
          <!-- 心跳保活，防止 NAT 超时断开 -->
          <param name="ping"             value="25"/>
          <param name="ping-max"         value="3"/>
          <param name="ping-min"         value="1"/>
          <!-- 主叫号码从 From 头取（false = 从 Contact 取） -->
          <param name="caller-id-in-from" value="true"/>
          <param name="caller-id-in-uri" value="true"/>
          <param name="extension" value="$${carrier_username}"/>
          <param name="contact-params"   value="transport=udp"/>
          <param name="from-user"   value="$${outbound_caller_id}"/>
          <param name="from-domain"   value="$${carrier_sip_server}"/>

          <!-- 🌟 自动加前缀（网关层处理，拨号计划无需手动拼） -->
          <param name="prefix" value="$${prefix}"/>
          
          <!-- 保活与超时 -->
          <param name="ping" value="25"/>
          <param name="expire-seconds" value="600"/>
          <param name="retry-seconds" value="30"/>
          
          <!-- 传输协议：6922 端口通常为 UDP，如供应商明确要求 TCP 请改为 tport=tcp -->
          <!-- <param name="contact-params" value="tport=udp"/> -->
        
        </gateway>

        <!-- 备用网关（主备容灾，主 gateway 失败自动切换） -->
        <!--
        <gateway name="carrier_trunk_backup">
          <param name="username"       value="BACKUP_USER"/>
          <param name="password"       value="BACKUP_PASS"/>
          <param name="proxy"          value="backup.carrier.com:5060"/>
          <param name="register"       value="true"/>
          <param name="expire-seconds" value="1800"/>
          <param name="retry-seconds"  value="30"/>
          <param name="ping"           value="25"/>
        </gateway>
        -->
      </gateways>

      <settings>
        <!-- 监听端口 -->
        <param name="sip-port" value="5080"/>
        <param name="sip-ip"   value="0.0.0.0"/>
        <param name="rtp-ip"   value="0.0.0.0"/>

        <!-- NAT 穿透（云服务器/公网部署必须配置） -->
        <param name="ext-sip-ip" value="$${external_sip_ip}"/>
        <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
        <param name="apply-nat-acl" value="nat.auto"/>
        <!-- STUN 服务器（用于探测公网 IP） -->
        <param name="stun-enabled"      value="true"/>
        <param name="stun-auto-disable" value="true"/>

        <!-- RTP 端口范围（每路通话占 2 个端口） -->
        <param name="rtp-start-port" value="$${rtp_start_port}"/>
        <param name="rtp-end-port"   value="$${rtp_end_port}"/>

        <!--
          ★ 编解码器优先级
          PCMU = G.711 μ-law (8kHz, 64kbps) → 零延迟，ASR 最友好
          PCMA = G.711 A-law (8kHz, 64kbps) → 国内运营商常见
          不建议在此加 G.729，G.729 压缩引入额外延迟影响 ASR
        -->
        <param name="inbound-codec-prefs"  value="PCMU,PCMA"/>
        <param name="outbound-codec-prefs" value="PCMU,PCMA"/>
        <!-- 允许延迟协商编解码（兼容性更好） -->
        <param name="inbound-late-negotiation" value="true"/>
        <!-- 编解码协商失败时继续（不挂断） -->
        <param name="inbound-zrtp-passthru"    value="true"/>

        <!--
          ★ DTMF 检测（用于用户按键响应）
          rfc2833 = 带外 DTMF，稳定性最好
          info     = SIP INFO，次选
          inband   = 音频带内，不推荐
        -->
        <param name="dtmf-type" value="rfc2833"/>

        <!-- 通话超时控制 -->
        <param name="session-timeout"      value="1800"/>
        <param name="rtp-timeout-sec"      value="300"/>
        <param name="rtp-hold-timeout-sec" value="1800"/>

        <!-- 媒体代理模式（proxy = 媒体经过 FS，必须开启才能录音/捕获音频） -->
        <param name="media-option" value="resume-media-on-hold"/>

        <!-- QoS 标记（让网络设备优先转发语音包） -->
        <param name="sip-tos" value="CS3"/>
        <param name="rtp-tos" value="EF"/>

        <!-- SIP 用户代理标识 -->
        <param name="user-agent-string" value="AI-OutboundCall/1.10"/>

        <!-- 进入拨号计划的上下文 -->
        <param name="context" value="outbound_calls"/>

        <!-- SIP 追踪（生产环境关闭，排障时设为 true） -->
        <param name="sip-trace" value="$${sip_trace}"/>

        <!-- 收到 BYE 后延迟处理（留时间给录音模块写文件） -->
        <param name="hangup-timeout-ms" value="500"/>

        <!-- 录音配置 -->
        <param name="record-path"   value="$${recording_base_dir}"/>
        <param name="record-format" value="wav"/>

        <!-- 禁用不需要的功能（减少攻击面） -->
        <param name="disable-register"   value="false"/>
        <param name="accept-blind-reg"   value="false"/>
        <param name="accept-blind-auth"  value="false"/>

        <!-- 100 Trying 自动回复 -->
        <param name="send-100-automatically" value="true"/>

        <!-- SIP 定时器 T1/T2（毫秒，影响重传间隔） -->
        <param name="sip-timer-T1" value="500"/>
        <param name="sip-timer-T2" value="4000"/>
      </settings>
    </profile>

    <!-- ============================================================
         内部分机 Profile（人工坐席软电话注册）
         端口 5060，局域网内使用
         ============================================================ -->
    <profile name="internal">
      <gateways/>
      <domains>
        <domain name="all" alias="true" parse="false"/>
      </domains>
      <settings>
        <param name="sip-port" value="$${internal_sip_port}"/>
        <param name="sip-ip"   value="0.0.0.0"/>
        <param name="rtp-ip"   value="0.0.0.0"/>

        <!-- 安全：只允许局域网注册 -->
        <param name="apply-inbound-acl"  value="domains"/>
        <param name="apply-register-acl" value="domains"/>
        <param name="local-network-acl"  value="localnet.auto"/>

        <!-- 需要鉴权 -->
        <param name="auth-calls"      value="true"/>
        <param name="auth-all-packets" value="false"/>

        <param name="inbound-codec-prefs"  value="PCMU,PCMA,G729"/>
        <param name="outbound-codec-prefs" value="PCMU,PCMA,G729"/>
        <param name="dtmf-type"            value="rfc2833"/>
        <param name="session-timeout"      value="1800"/>
        <param name="context"              value="internal"/>
        <param name="hold-music"           value="$${hold_music}"/>
        <param name="user-agent-string"    value="AI-OutboundCall-Internal/1.10"/>
        <param name="sip-trace"            value="false"/>

        <!-- 注册处理 -->
        <param name="multiple-registrations" value="contact"/>
        <param name="max-auth-validity"      value="100"/>
      </settings>
    </profile>
  </profiles>

</configuration>
