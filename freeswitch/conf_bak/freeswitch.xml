<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║         FreeSWITCH 主配置文件 freeswitch.xml                 ║
  ║         智能外呼系统 - AI Outbound Call System               ║
  ╚══════════════════════════════════════════════════════════════╝

  这是 FreeSWITCH 的入口配置，加载顺序：
  1. 全局变量 (vars.xml)
  2. 模块加载列表 (modules.conf.xml)
  3. 各模块配置 (autoload_configs/*.conf.xml)
  4. 拨号计划 (dialplan/)
  5. 用户目录 (directory/)

  配置目录通常位于 /etc/freeswitch/ 或 /usr/local/freeswitch/conf/
  启动时指定: freeswitch -conf /path/to/conf -log /var/log/freeswitch
-->
<document type="freeswitch/xml">

  <!-- ============================================================
       第一节：全局变量
       所有 XML 中可用 $${变量名} 引用
       ============================================================ -->
  <section name="configuration" description="全局配置">
    <configuration name="switch.conf" description="核心开关配置">
      <settings>
        <!-- 进程优先级，-19 表示最高优先级（实时通话需要） -->
        <param name="priority" value="-19"/>
        <!-- 最大会话数（并发通话上限） -->
        <param name="max-sessions" value="1000"/>
        <!-- 每秒最多建立新会话数（防止突发流量打垮系统） -->
        <param name="sessions-per-second" value="100"/>
        <!-- 默认拨号超时（秒） -->
        <param name="default-ring-duration" value="60"/>
        <!-- RTP 超时（秒），超过此时长无 RTP 包则挂断 -->
        <param name="rtp-start-timeout-sec" value="300"/>
        <!-- 媒体超时保护 -->
        <param name="media-timeout" value="0"/>
        <!-- 日志级别：DEBUG=7, INFO=6, NOTICE=5, WARNING=4, ERR=3 -->
        <param name="loglevel" value="info"/>
        <!-- 控制台日志颜色 -->
        <param name="colorize-console" value="true"/>
        <!-- 运行用户（安全建议：不要用 root） -->
        <!-- <param name="runas-username" value="freeswitch"/> -->
        <!-- <param name="runas-groupname" value="freeswitch"/> -->
        <!-- 核心 dump（调试用） -->
        <param name="dump-cores" value="yes"/>
      </settings>
    </configuration>
  </section>

  <!-- ============================================================
       第二节：引入全局变量文件
       ============================================================ -->
  <X-PRE-PROCESS cmd="include" data="vars.xml"/>

  <!-- ============================================================
       第三节：引入模块配置
       ============================================================ -->
  <section name="configuration" description="模块配置">
    <X-PRE-PROCESS cmd="include" data="autoload_configs/*.conf.xml"/>
  </section>

  <!-- ============================================================
       第四节：拨号计划
       ============================================================ -->
  <section name="dialplan" description="拨号计划">
    <X-PRE-PROCESS cmd="include" data="dialplan/*.xml"/>
  </section>

  <!-- ============================================================
       第五节：用户目录（SIP 注册账号）
       ============================================================ -->
  <section name="directory" description="用户目录">
    <X-PRE-PROCESS cmd="include" data="directory/*.xml"/>
  </section>

  <!-- ============================================================
       第六节：短语/语音提示
       ============================================================ -->
  <section name="phrases" description="语音提示宏">
    <macros/>
  </section>

</document>
